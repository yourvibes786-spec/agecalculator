---
import {
  calculateExactAge,
  calculateNextBirthday,
  calculateTotalUnits,
  getZodiacSign,
  getChineseZodiac,
  calculateMilestones,
  calculateStats,
  calculateLifeProgress,
  calculatePlanetaryAges,
} from "../utils/age";
---

<div
  class="relative min-h-screen overflow-hidden flex flex-col justify-between"
>
  <!-- Mesh Gradient Background -->
  <div class="mesh-gradient-bg"></div>

  <!-- Header Nav -->
  <header
    class="sticky top-0 z-50 w-full bg-canvas/80 backdrop-blur-md border-b border-hairline shadow-level-1 h-16 transition-all"
  >
    <div
      class="max-w-[1200px] h-full mx-auto px-4 md:px-6 flex items-center justify-between"
    >
      <!-- Title -->
      <a href="/" class="flex items-center gap-2 focus-ring rounded-sm py-1">
        <span class="font-mono text-xs font-semibold tracking-widest text-mute"
          >0.0.1</span
        >
        <span
          class="font-sans font-semibold text-lg tracking-tight select-none text-ink"
          >AGE CALCULATOR.</span
        >
      </a>

      <!-- Reset / New Calculation -->
      <button
        id="reset-btn"
        class="hidden px-3 py-1.5 bg-canvas hover:bg-canvas-soft-2 text-ink border border-hairline rounded-sm font-mono text-xs font-semibold uppercase tracking-wider focus-ring transition cursor-pointer"
        type="button"
      >
        Reset Form
      </button>

      <!-- Dark Mode Toggle -->
      <button
        type="button"
        id="theme-toggle"
        aria-label="Toggle dark mode"
        class="px-3 py-1.5 bg-canvas hover:bg-canvas-soft-2 text-ink border border-hairline rounded-sm font-mono text-xs font-semibold uppercase tracking-wider focus-ring transition cursor-pointer"
      >
        Dark Mode
      </button>
    </div>
  </header>

  <!-- Main Content Area -->
  <main
    class="relative z-10 flex-grow w-full max-w-[1200px] mx-auto px-4 md:px-6 py-12 flex flex-col justify-center"
  >
    <!-- 1. LANDING / FORM VIEW -->
    <div
      id="landing-view"
      class="w-full max-w-4xl mx-auto flex flex-col items-center justify-center animate-fade-in"
    >
      <!-- Hero Intro -->
      <div class="text-center mb-10 max-w-2xl">
        <span
          class="inline-flex items-center gap-1.5 px-3 py-1 mb-4 rounded-full bg-link-bg-soft border border-link/10 text-link font-mono text-xs font-medium"
        >
          <svg
            class="w-3.5 h-3.5 animate-pulse"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          Precise to the second
        </span>
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-display-xl text-ink leading-tight mb-4 select-text"
        >
          Discover your time on Earth.
        </h1>
        <p class="text-lg text-body font-normal select-text leading-relaxed">
          Enter your birth details to calculate your exact age in real time, map
          cosmic stats, count down to your next birthday, trace key milestones,
          and generate a customized share card.
        </p>
      </div>

      <!-- Form Card -->
      <div
        class="w-full max-w-lg bg-canvas border border-hairline shadow-level-3 rounded-lg p-6 md:p-8 mb-16"
      >
        <form id="age-form" class="space-y-6" novalidate>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- Birth Date Input -->
            <div class="space-y-2">
              <label
                for="birth-date"
                class="block font-mono text-xs font-semibold text-mute tracking-wider uppercase"
              >
                Birth Date *
              </label>
              <input
                type="date"
                id="birth-date"
                name="birth-date"
                required
                aria-required="true"
                class="w-full h-10 px-3 bg-canvas text-ink border border-hairline focus-ring rounded-sm text-sm font-sans"
              />
              <span
                id="date-error"
                class="hidden text-xs text-error font-medium flex items-center gap-1 animate-fade-in"
              >
                <svg
                  class="w-3.5 h-3.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                  ></path>
                </svg>
                Please select a valid past date
              </span>
            </div>

            <!-- Birth Time Input -->
            <div class="space-y-2">
              <label
                for="birth-time"
                class="block font-mono text-xs font-semibold text-mute tracking-wider uppercase"
              >
                Birth Time (Optional)
              </label>
              <input
                type="time"
                id="birth-time"
                name="birth-time"
                class="w-full h-10 px-3 bg-canvas text-ink border border-hairline focus-ring rounded-sm text-sm font-sans"
              />
            </div>
          </div>

          <!-- CTA Submit -->
          <button
            type="submit"
            id="submit-btn"
            class="w-full h-12 inline-flex items-center justify-center bg-primary hover:bg-neutral-800 text-on-primary font-sans font-medium text-sm rounded-pill focus-ring transition shadow-level-2 cursor-pointer"
          >
            Calculate Age.
          </button>

          <!-- Privacy Footer -->
          <div
            class="pt-4 border-t border-hairline flex items-center justify-center gap-2"
          >
            <svg
              class="w-4 h-4 text-mute"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
              ></path>
            </svg>
            <span
              class="font-mono text-[10px] text-mute uppercase tracking-widest leading-none"
            >
              Privacy First: Calculations run 100% locally
            </span>
          </div>
        </form>
      </div>

      <!-- Feature Grid (3-Up) -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full text-left">
        <!-- Feature 1 -->
        <div
          class="bg-canvas border border-hairline rounded-md p-6 shadow-level-2 transition-transform hover:-translate-y-0.5"
        >
          <div
            class="w-10 h-10 rounded-sm bg-canvas-soft border border-hairline flex items-center justify-center mb-4 text-primary"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-ink mb-2">
            Real-time Ticking
          </h3>
          <p class="text-sm text-body leading-relaxed">
            Watch your exact age increment in real time down to the second. Life
            moves quickly—watch every second count.
          </p>
        </div>
        <!-- Feature 2 -->
        <div
          class="bg-canvas border border-hairline rounded-md p-6 shadow-level-2 transition-transform hover:-translate-y-0.5"
        >
          <div
            class="w-10 h-10 rounded-sm bg-canvas-soft border border-hairline flex items-center justify-center mb-4 text-primary"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 002 2h2a2.5 2.5 0 002.5-2.5V10a2 2 0 012-2h1.25M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-ink mb-2">
            Cosmic Perspective
          </h3>
          <p class="text-sm text-body leading-relaxed">
            Learn how many miles you have traveled through space, average
            breaths taken, and moon orbits made during your lifespan.
          </p>
        </div>
        <!-- Feature 3 -->
        <div
          class="bg-canvas border border-hairline rounded-md p-6 shadow-level-2 transition-transform hover:-translate-y-0.5"
        >
          <div
            class="w-10 h-10 rounded-sm bg-canvas-soft border border-hairline flex items-center justify-center mb-4 text-primary"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-ink mb-2">
            Milestone Tracker
          </h3>
          <p class="text-sm text-body leading-relaxed">
            See the exact calendar dates you turn 1,000, 10,000, or 25,000 days
            lived, and get countdowns to upcoming ones.
          </p>
        </div>
      </div>
    </div>

    <!-- 2. DASHBOARD VIEW -->
    <div
      id="dashboard-view"
      class="hidden w-full flex flex-col gap-10 animate-fade-in"
    >
      <!-- Exact Age Banner (Real-time Live Tick) -->
      <div
        class="w-full bg-canvas border border-hairline shadow-level-2 rounded-lg p-6 md:p-8 flex flex-col items-center"
      >
        <span
          class="font-mono text-xs font-semibold text-mute tracking-widest uppercase mb-4"
        >
          Exact Elapsed Age (Ticking Live)
        </span>

        <!-- Age counter Grid -->
        <div class="grid grid-cols-3 md:grid-cols-6 gap-4 w-full">
          <!-- Years -->
          <div
            class="bg-canvas-soft border border-hairline shadow-level-1 rounded-sm p-4 flex flex-col items-center text-center"
          >
            <span
              id="age-years"
              aria-live="polite"
              class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-ink tabular-nums"
              >0</span
            >
            <span
              class="font-mono text-[10px] text-mute font-semibold tracking-wider uppercase mt-1"
              >Years</span
            >
          </div>
          <!-- Months -->
          <div
            class="bg-canvas-soft border border-hairline shadow-level-1 rounded-sm p-4 flex flex-col items-center text-center"
          >
            <span
              id="age-months"
              aria-live="polite"
              class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-ink tabular-nums"
              >0</span
            >
            <span
              class="font-mono text-[10px] text-mute font-semibold tracking-wider uppercase mt-1"
              >Months</span
            >
          </div>
          <!-- Days -->
          <div
            class="bg-canvas-soft border border-hairline shadow-level-1 rounded-sm p-4 flex flex-col items-center text-center"
          >
            <span
              id="age-days"
              aria-live="polite"
              class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-ink tabular-nums"
              >0</span
            >
            <span
              class="font-mono text-[10px] text-mute font-semibold tracking-wider uppercase mt-1"
              >Days</span
            >
          </div>
          <!-- Hours -->
          <div
            class="bg-canvas-soft border border-hairline shadow-level-1 rounded-sm p-4 flex flex-col items-center text-center"
          >
            <span
              id="age-hours"
              aria-live="polite"
              class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-ink tabular-nums"
              >0</span
            >
            <span
              class="font-mono text-[10px] text-mute font-semibold tracking-wider uppercase mt-1"
              >Hours</span
            >
          </div>
          <!-- Minutes -->
          <div
            class="bg-canvas-soft border border-hairline shadow-level-1 rounded-sm p-4 flex flex-col items-center text-center"
          >
            <span
              id="age-minutes"
              aria-live="polite"
              class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-ink tabular-nums"
              >0</span
            >
            <span
              class="font-mono text-[10px] text-mute font-semibold tracking-wider uppercase mt-1"
              >Minutes</span
            >
          </div>
          <!-- Seconds -->
          <div
            class="bg-canvas-soft border border-hairline shadow-level-1 rounded-sm p-4 flex flex-col items-center text-center border-link/20 ring-1 ring-link/10"
          >
            <span
              id="age-seconds"
              aria-live="polite"
              class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-link tabular-nums"
              >0</span
            >
            <span
              class="font-mono text-[10px] text-link font-semibold tracking-wider uppercase mt-1 animate-pulse"
              >Seconds</span
            >
          </div>
        </div>
      </div>

      <!-- Tab Buttons Navigation -->
      <div
        class="w-full flex items-center justify-center border-b border-hairline overflow-x-auto no-scrollbar py-1"
      >
        <div
          class="inline-flex space-x-1 bg-canvas-soft-2 p-1 rounded-pill-sm border border-hairline flex-nowrap"
        >
          <button
            type="button"
            class="tab-btn active px-4 py-1.5 text-sm font-medium rounded-pill-sm transition cursor-pointer select-none text-on-primary bg-primary"
            data-tab="overview"
            id="tab-btn-overview"
          >
            Overview
          </button>
          <button
            type="button"
            class="tab-btn px-4 py-1.5 text-sm font-medium rounded-pill-sm transition cursor-pointer select-none text-body hover:text-ink hover:bg-canvas"
            data-tab="units"
            id="tab-btn-units"
          >
            Time Units
          </button>
          <button
            type="button"
            class="tab-btn px-4 py-1.5 text-sm font-medium rounded-pill-sm transition cursor-pointer select-none text-body hover:text-ink hover:bg-canvas"
            data-tab="milestones"
            id="tab-btn-milestones"
          >
            Milestones
          </button>
          <button
            type="button"
            class="tab-btn px-4 py-1.5 text-sm font-medium rounded-pill-sm transition cursor-pointer select-none text-body hover:text-ink hover:bg-canvas"
            data-tab="stats"
            id="tab-btn-stats"
          >
            Fun Facts
          </button>
        </div>
      </div>

      <!-- Tab Content Panels -->
      <div id="tab-content" class="w-full">
        <!-- TAB A: OVERVIEW -->
        <div
          id="tab-overview"
          class="tab-panel w-full grid grid-cols-1 lg:grid-cols-3 gap-6 animate-fade-in"
        >
          <!-- Column 1: Next Birthday Countdown -->
          <div
            class="bg-canvas border border-hairline rounded-lg p-6 shadow-level-2 flex flex-col justify-between"
          >
            <div>
              <div class="flex items-center gap-2 mb-4">
                <div
                  class="w-8 h-8 rounded-sm bg-canvas-soft border border-hairline flex items-center justify-center text-primary"
                >
                  <svg
                    class="w-4.5 h-4.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M21 15.546c0 .58-.33 1.1-.86 1.33L12 21l-8.14-4.124a1.5 1.5 0 01-.86-1.33V6.453c0-.58.33-1.1.86-1.33L12 1l8.14 4.124c.53.23.86.75.86 1.33v9.093z"
                    ></path>
                  </svg>
                </div>
                <h3
                  class="text-sm font-semibold text-ink uppercase tracking-wider font-mono"
                >
                  Next Birthday
                </h3>
              </div>

              <!-- Countdown Circle Visualizer -->
              <div class="flex items-center justify-center py-6">
                <div
                  class="relative w-40 h-40 flex items-center justify-center"
                >
                  <!-- Backgound Circle -->
                  <svg class="absolute inset-0 w-full h-full -rotate-90">
                    <circle
                      cx="80"
                      cy="80"
                      r="70"
                      stroke="var(--color-hairline)"
                      stroke-width="6"
                      fill="transparent"></circle>
                    <!-- Progress Circle -->
                    <circle
                      id="countdown-progress"
                      cx="80"
                      cy="80"
                      r="70"
                      stroke="var(--color-primary)"
                      stroke-width="7"
                      fill="transparent"
                      stroke-dasharray="440"
                      stroke-dashoffset="440"
                      stroke-linecap="round"
                      class="transition-all duration-1000 ease-out"></circle>
                  </svg>
                  <!-- Value display inside -->
                  <div
                    class="flex flex-col items-center justify-center text-center px-4"
                  >
                    <span
                      id="countdown-days"
                      aria-live="polite"
                      class="text-3xl font-bold tracking-tight text-ink tabular-nums"
                      >0</span
                    >
                    <span
                      class="font-mono text-[9px] text-mute font-semibold uppercase tracking-widest mt-0.5"
                      >Days Left</span
                    >
                  </div>
                </div>
              </div>
            </div>

            <!-- Summary Countdown timer details -->
            <div class="mt-4 pt-4 border-t border-hairline text-center">
              <p
                id="countdown-text"
                aria-live="polite"
                class="text-xs text-body font-mono mb-2"
              >
                0 months & 0 days remaining
              </p>
              <div
                id="countdown-clock"
                aria-live="polite"
                class="text-xs font-mono font-semibold text-primary select-text bg-canvas-soft-2 rounded-sm py-1.5 px-2 tabular-nums"
              >
                00:00:00:00
              </div>
            </div>
          </div>

          <!-- Column 2: Astronomical & Birthday Metadata -->
          <div
            class="bg-canvas border border-hairline rounded-lg p-6 shadow-level-2 flex flex-col justify-between"
          >
            <div class="space-y-6">
              <div class="flex items-center gap-2">
                <div
                  class="w-8 h-8 rounded-sm bg-canvas-soft border border-hairline flex items-center justify-center text-primary"
                >
                  <svg
                    class="w-4.5 h-4.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                  </svg>
                </div>
                <h3
                  class="text-sm font-semibold text-ink uppercase tracking-wider font-mono"
                >
                  Personal Profile
                </h3>
              </div>

              <!-- Metrics -->
              <div class="space-y-4">
                <!-- Day Born -->
                <div
                  class="flex items-center justify-between py-2 border-b border-hairline"
                >
                  <span class="text-sm text-body font-medium">Day of Birth</span
                  >
                  <span
                    id="profile-day-born"
                    class="font-mono text-xs font-semibold text-primary"
                    >Unknown</span
                  >
                </div>
                <!-- Zodiac -->
                <div
                  class="flex items-center justify-between py-2 border-b border-hairline"
                >
                  <span class="text-sm text-body font-medium">Zodiac Sign</span>
                  <span class="flex items-center gap-1.5">
                    <span id="profile-zodiac-symbol" class="text-sm">♈</span>
                    <span
                      id="profile-zodiac-name"
                      class="font-sans text-sm font-semibold text-primary"
                      >Aries</span
                    >
                    <span
                      id="profile-zodiac-dates"
                      class="font-mono text-[10px] text-mute font-semibold"
                      >Mar 21 - Apr 19</span
                    >
                  </span>
                </div>
                <!-- Chinese Zodiac -->
                <div
                  class="flex items-center justify-between py-2 border-b border-hairline"
                >
                  <span class="text-sm text-body font-medium"
                    >Chinese Zodiac</span
                  >
                  <span class="flex items-center gap-1.5">
                    <span id="profile-chinese-symbol" class="text-sm">🐀</span>
                    <span
                      id="profile-chinese-name"
                      class="font-sans text-sm font-semibold text-primary"
                      >Rat</span
                    >
                    <span
                      id="profile-chinese-element"
                      class="font-mono text-[10px] text-mute bg-canvas-soft px-1.5 py-0.5 rounded border border-hairline font-semibold"
                      >Metal</span
                    >
                  </span>
                </div>
              </div>
            </div>

            <!-- Chinese traits summary -->
            <div
              id="profile-chinese-traits"
              class="mt-4 p-3 bg-canvas-soft border border-hairline rounded-sm font-mono text-[10px] text-mute uppercase tracking-wider leading-relaxed"
            >
              Traits description
            </div>

            <!-- Life Progress Dashboard (V2) -->
            <div
              class="mt-6 bg-canvas-soft border border-hairline rounded-lg p-4 shadow-level-1"
            >
              <div class="flex items-center justify-between gap-2 mb-3">
                <h4
                  class="text-sm font-semibold text-ink uppercase tracking-wider font-mono"
                >
                  Life Progress
                </h4>
                <span
                  class="font-mono text-[10px] text-mute uppercase tracking-widest"
                >
                  Premium
                </span>
              </div>

              <div class="space-y-3">
                <div class="flex items-center justify-between gap-3">
                  <label
                    for="life-expectancy-years"
                    class="text-xs text-body font-mono font-semibold uppercase tracking-wider"
                  >
                    Life Expectancy (Years)
                  </label>
                  <input
                    type="number"
                    id="life-expectancy-years"
                    min="1"
                    max="130"
                    step="1"
                    inputmode="numeric"
                    class="w-20 h-9 px-3 bg-canvas text-ink border border-hairline focus-ring rounded-sm text-sm font-mono"
                  />
                </div>

                <div class="grid grid-cols-3 gap-3">
                  <div class="text-center">
                    <span
                      id="life-years-remaining"
                      class="text-2xl font-bold tracking-tight text-ink tabular-nums"
                      >0</span
                    >
                    <div
                      class="text-[10px] text-body font-mono font-semibold uppercase tracking-wider mt-0.5"
                    >
                      Years
                    </div>
                  </div>
                  <div class="text-center">
                    <span
                      id="life-months-remaining"
                      class="text-2xl font-bold tracking-tight text-ink tabular-nums"
                      >0</span
                    >
                    <div
                      class="text-[10px] text-body font-mono font-semibold uppercase tracking-wider mt-0.5"
                    >
                      Months
                    </div>
                  </div>
                  <div class="text-center">
                    <span
                      id="life-weeks-remaining"
                      class="text-2xl font-bold tracking-tight text-ink tabular-nums"
                      >0</span
                    >
                    <div
                      class="text-[10px] text-body font-mono font-semibold uppercase tracking-wider mt-0.5"
                    >
