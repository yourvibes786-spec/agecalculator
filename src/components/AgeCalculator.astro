      }

      // Fallback: clipboard copy
      await navigator.clipboard.writeText(shareText);
      copyBtnText.textContent = "Copied for sharing!";
      setTimeout(() => {
        copyBtnText.textContent = "Copy Summary Text";
      }, 2000);
    } catch (err) {
      console.error("Web share failed", err);
    }
