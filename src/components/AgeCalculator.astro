                  >Earth Orbits</span
                >
                <span
                  id="stat-earth-orbits-completed"
                  class="text-xl md:text-2xl font-bold tracking-tight text-ink tabular-nums"
                  >0</span
                >
              </div>
            </div>
          </div>

          <!-- Phase 3: Historical Context -->
          <div
            class="col-span-1 md:col-span-2 bg-canvas border border-hairline rounded-lg p-6 shadow-level-2"
          >
            <div class="flex items-center justify-between gap-2 mb-4">
              <h4
                class="text-sm font-semibold text-ink uppercase tracking-wider font-mono"
              >
                Historical Context
              </h4>
              <span
                class="font-mono text-[10px] text-mute uppercase tracking-widest"
                >After Your Birth</span
              >
            </div>
            <div
              id="historical-context-container"
              class="grid grid-cols-1 sm:grid-cols-2 gap-4"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Invisible Anchor Canvas for Share Card PNG Rendering -->
  <canvas id="share-card-canvas" width="1200" height="630" class="hidden"
  ></canvas>
</div>

<script>
  import {
    calculateExactAge,
    calculateNextBirthday,
    calculateTotalUnits,
    getZodiacSign,
    getChineseZodiac,
    calculateMilestones,
    calculateStats,
    calculateLifeProgress,
    calculatePlanetaryAges,
    calculateLifeStatistics,
    calculateAgeComparisonCards,
    calculateHistoricalContext,
    calculateBornInSnapshot,
    getGenerationLabel,
  } from "../utils/age";

  // Global variables to store the active birthdate
  let activeBirthDate: Date | null = null;
  let timerId: any = null;

  // DOM Elements
  const landingView = document.getElementById("landing-view")!;
  const dashboardView = document.getElementById("dashboard-view")!;
  const ageForm = document.getElementById("age-form") as HTMLFormElement;
  const birthDateInput = document.getElementById(
    "birth-date",
  ) as HTMLInputElement;
  const birthTimeInput = document.getElementById(
    "birth-time",
  ) as HTMLInputElement;
  const dateError = document.getElementById("date-error")!;
  const resetBtn = document.getElementById("reset-btn")!;

  // Counter Elements
  const yCounter = document.getElementById("age-years")!;
  const mCounter = document.getElementById("age-months")!;
  const dCounter = document.getElementById("age-days")!;
  const hCounter = document.getElementById("age-hours")!;
  const minCounter = document.getElementById("age-minutes")!;
  const sCounter = document.getElementById("age-seconds")!;

  // Unit Elements
  const mTotal = document.getElementById("unit-months")!;
  const wTotal = document.getElementById("unit-weeks")!;
  const dTotal = document.getElementById("unit-days")!;
  const hTotal = document.getElementById("unit-hours")!;
  const minTotal = document.getElementById("unit-minutes")!;
  const sTotal = document.getElementById("unit-seconds")!;

  // Overview Profile Elements
  const profileDayBorn = document.getElementById("profile-day-born")!;
  const profileZodiacSymbol = document.getElementById("profile-zodiac-symbol")!;
  const profileZodiacName = document.getElementById("profile-zodiac-name")!;
  const profileChineseSymbol = document.getElementById(
    "profile-chinese-symbol",
  )!;
  const profileChineseName = document.getElementById("profile-chinese-name")!;
  const profileChineseElement = document.getElementById(
    "profile-chinese-element",
  )!;
  const profileChineseTraits = document.getElementById(
    "profile-chinese-traits",
  )!;

  // Next Birthday Countdown Elements
  const countdownProgress = document.getElementById(
    "countdown-progress",
  ) as unknown as SVGCircleElement;
  const countdownDays = document.getElementById("countdown-days")!;
  const countdownText = document.getElementById("countdown-text")!;
  const countdownClock = document.getElementById("countdown-clock")!;

  // Life Progress (V2)
  const lifeExpectancyYearsInput = document.getElementById(
    "life-expectancy-years",
  ) as HTMLInputElement;
  const lifeYearsRemaining = document.getElementById("life-years-remaining")!;
  const lifeMonthsRemaining = document.getElementById("life-months-remaining")!;
  const lifeWeeksRemaining = document.getElementById("life-weeks-remaining")!;
  const lifeDaysRemaining = document.getElementById("life-days-remaining")!;
  const lifeCompletionPercent = document.getElementById(
    "life-completion-percent",
  )!;
  const lifeRemainingPercent = document.getElementById(
    "life-remaining-percent",
  )!;
  const lifeCompletionRatioBar = document.getElementById(
    "life-completion-bar",
  )! as HTMLDivElement;
  const lifeExpectancyDate = document.getElementById("life-expectancy-date")!;

  // Milestones timeline
  const milestonesTimeline = document.getElementById("milestones-timeline")!;

  const statSolarTravel = document.getElementById("stat-solar-travel")!;

  // Phase 3 containers
  const comparisonCardsContainer = document.getElementById(
    "comparison-cards-container",
  )!;
  const historicalContextContainer = document.getElementById(
    "historical-context-container",
  )!;
  const bornInContainer = document.getElementById("born-in-container")!;

  const statLeapYearsWitnessed = document.getElementById(
    "stat-leap-years-witnessed",
  )!;
  const statMoonCyclesCompleted = document.getElementById(
    "stat-moon-cycles-completed",
  )!;
  const statEarthOrbitsCompleted = document.getElementById(
    "stat-earth-orbits-completed",
  )!;

  // Planetary Age Explorer (V2)
  const planetaryMercury = document.getElementById("planetary-mercury")!;
  const planetaryVenus = document.getElementById("planetary-venus")!;
  const planetaryMars = document.getElementById("planetary-mars")!;
  const planetaryJupiter = document.getElementById("planetary-jupiter")!;
  const planetarySaturn = document.getElementById("planetary-saturn")!;

  // Action Elements
  const copySummaryBtn = document.getElementById("copy-summary-btn")!;
  const copyBtnText = document.getElementById("copy-btn-text")!;
  const downloadCardBtn = document.getElementById("download-card-btn")!;
  const shareWebBtn = document.getElementById("share-web-btn")!;

  // Share Card Preview elements
  const shareCardAge = document.getElementById("share-card-age")!;
  const shareCardDays = document.getElementById("share-card-days")!;
  const shareCardCountdown = document.getElementById("share-card-countdown")!;
  const shareCardProgressEl = document.getElementById("share-card-progress")!;
  const shareCardGenerationEl = document.getElementById(
    "share-card-generation",
  )!;
  const shareCardZodiacEl = document.getElementById("share-card-zodiac")!;

  // 1. Initial State / LocalStorage loading
  window.addEventListener("DOMContentLoaded", () => {
    // Theme (Dark Mode) persistence
    const savedTheme = localStorage.getItem("theme");
    const theme =
      savedTheme === "dark" || savedTheme === "light" ? savedTheme : "light";
    document.documentElement.setAttribute("data-theme", theme);

    const themeToggle = document.getElementById("theme-toggle");
    if (themeToggle) {
      themeToggle.textContent = theme === "dark" ? "Light Mode" : "Dark Mode";
      themeToggle.addEventListener("click", () => {
        const current = document.documentElement.getAttribute("data-theme");
        const next = current === "dark" ? "light" : "dark";
        document.documentElement.setAttribute("data-theme", next);
        localStorage.setItem("theme", next);
        themeToggle.textContent = next === "dark" ? "Light Mode" : "Dark Mode";

        // Re-render share card canvas backgrounds for theme coherence
        if (activeBirthDate) {
          runCalculations(false);
        }
      });
    }

    const savedDate = localStorage.getItem("birth-date");
    const savedTime = localStorage.getItem("birth-time");

    // Set default max date to today
    const today = new Date().toISOString().split("T")[0];
    birthDateInput.max = today;

    // Life expectancy preference (V2)
    const savedExpectancy = localStorage.getItem("life-expectancy-years");
    const defaultExpectancy = 85;
    const parsedExpectancy = savedExpectancy
      ? Math.min(130, Math.max(1, parseInt(savedExpectancy, 10)))
      : defaultExpectancy;
    lifeExpectancyYearsInput.value = parsedExpectancy.toString();
    localStorage.setItem("life-expectancy-years", parsedExpectancy.toString());

    // Persist preference on change
    lifeExpectancyYearsInput.addEventListener("input", () => {
      const v = Math.min(
        130,
        Math.max(
          1,
          parseInt(lifeExpectancyYearsInput.value || "0", 10) ||
            defaultExpectancy,
        ),
      );
      lifeExpectancyYearsInput.value = v.toString();
      localStorage.setItem("life-expectancy-years", v.toString());

      // Update dashboard if active
      if (activeBirthDate) runCalculations(false);
    });

    if (savedDate) {
      birthDateInput.value = savedDate;
      if (savedTime) birthTimeInput.value = savedTime;

      const birthDate = parseBirthDateTime(savedDate, savedTime || "00:00");
      if (birthDate && birthDate.getTime() < new Date().getTime()) {
        activateDashboard(birthDate);
      }
    }
  });

  // Helper to parse birthdate inputs
  function parseBirthDateTime(dateStr: string, timeStr: string): Date | null {
    if (!dateStr) return null;
    const time = timeStr || "00:00";
    const date = new Date(`${dateStr}T${time}`);
    return isNaN(date.getTime()) ? null : date;
  }

  // 2. Tab Navigation Trigger
  const tabButtons = document.querySelectorAll(".tab-btn");
  const tabPanels = document.querySelectorAll(".tab-panel");

  tabButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const targetTab = btn.getAttribute("data-tab");

      // Update buttons style + ARIA
      tabButtons.forEach((b) => {
        b.classList.remove("active", "text-on-primary", "bg-primary");
        b.classList.add("text-body", "hover:text-ink", "hover:bg-canvas");
        b.setAttribute("aria-selected", "false");
      });
      btn.classList.add("active", "text-on-primary", "bg-primary");
      btn.classList.remove("text-body", "hover:text-ink", "hover:bg-canvas");
      btn.setAttribute("aria-selected", "true");

      // Update panel visibility
      tabPanels.forEach((panel) => {
        panel.classList.add("hidden");
      });
      const activePanel = document.getElementById(`tab-${targetTab}`);
      if (activePanel) {
        activePanel.classList.remove("hidden");
      }
    });
  });

  // 3. Form Submission
  ageForm.addEventListener("submit", (e) => {
    e.preventDefault();
    dateError.classList.add("hidden");

    const dateVal = birthDateInput.value;
    const timeVal = birthTimeInput.value || "00:00";

    const birthDate = parseBirthDateTime(dateVal, timeVal);

    if (!birthDate || birthDate.getTime() >= new Date().getTime()) {
      dateError.classList.remove("hidden");
      return;
    }

    // Save to LocalStorage
    localStorage.setItem("birth-date", dateVal);
    localStorage.setItem("birth-time", timeVal);

    activateDashboard(birthDate);
  });

  // 4. Activate Dashboard
  function activateDashboard(birthDate: Date) {
    activeBirthDate = birthDate;

    // Hide form, show dashboard
    landingView.classList.add("hidden");
    dashboardView.classList.remove("hidden");
    resetBtn.classList.remove("hidden");

    // Run first calculations
    runCalculations(true);

    // Set interval for live counter updates (every second)
    if (timerId) clearInterval(timerId);
    timerId = setInterval(() => runCalculations(false), 1000);
  }

  // 5. Reset Form Actions
  resetBtn.addEventListener("click", () => {
    // Clear state
    activeBirthDate = null;
    if (timerId) {
      clearInterval(timerId);
      timerId = null;
    }

    // Clear inputs and LocalStorage
    birthDateInput.value = "";
    birthTimeInput.value = "";
    localStorage.removeItem("birth-date");
    localStorage.removeItem("birth-time");

    // Hide dashboard, show form
    dashboardView.classList.add("hidden");
    resetBtn.classList.add("hidden");
    landingView.classList.remove("hidden");

    // Reset tabs
    document.getElementById("tab-btn-overview")?.click();
  });

  // 6. Primary Calculation Runner
  // runs once with full = true (renders DOM nodes like Milestones that don't need second-by-second changes)
  function runCalculations(firstLoad: boolean) {
    if (!activeBirthDate) return;
    const now = new Date();

    // Calculate details
    const age = calculateExactAge(activeBirthDate, now);
    const nextBDay = calculateNextBirthday(activeBirthDate, now);
    const totalUnits = calculateTotalUnits(activeBirthDate, now);
    const zodiac = getZodiacSign(activeBirthDate);
    const chineseZ = getChineseZodiac(activeBirthDate.getFullYear());
    const stats = calculateStats(activeBirthDate, now);

    // Update Exact Age Display
    yCounter.textContent = age.years.toString();
    mCounter.textContent = age.months.toString();
    dCounter.textContent = age.days.toString();
    hCounter.textContent = age.hours.toString();
    minCounter.textContent = age.minutes.toString();
    sCounter.textContent = age.seconds.toString();

    // Update Total Units
    mTotal.textContent = totalUnits.months.toLocaleString();
    wTotal.textContent = totalUnits.weeks.toLocaleString();
    dTotal.textContent = totalUnits.days.toLocaleString();
    hTotal.textContent = totalUnits.hours.toLocaleString();
    minTotal.textContent = totalUnits.minutes.toLocaleString();
    sTotal.textContent = totalUnits.seconds.toLocaleString();

    statSolarTravel.textContent = stats.solarTravelKm.toLocaleString();

    const lifeStats = calculateLifeStatistics(activeBirthDate, now);
    statLeapYearsWitnessed.textContent =
      lifeStats.leapYearsWitnessed.toLocaleString();
    statMoonCyclesCompleted.textContent =
      lifeStats.moonCyclesCompleted.toLocaleString();
    statEarthOrbitsCompleted.textContent =
      lifeStats.earthOrbitsCompleted.toLocaleString();

    // Update Planetary Ages (V2)
    const planetary = calculatePlanetaryAges(activeBirthDate, now);
    planetaryMercury.textContent = planetary.mercury.toFixed(1);
    planetaryVenus.textContent = planetary.venus.toFixed(1);
    planetaryMars.textContent = planetary.mars.toFixed(1);
    planetaryJupiter.textContent = planetary.jupiter.toFixed(1);
    planetarySaturn.textContent = planetary.saturn.toFixed(1);

    // Life Progress Dashboard (V2)
    const expectancyYears = Math.min(
      130,
      Math.max(1, parseInt(lifeExpectancyYearsInput.value || "85", 10) || 85),
    );
    const life = calculateLifeProgress(activeBirthDate, now, expectancyYears);
    lifeYearsRemaining.textContent = life.yearsRemaining.toString();
    lifeMonthsRemaining.textContent = life.monthsRemaining.toString();
    lifeWeeksRemaining.textContent = life.weeksRemaining.toString();
    // Phase 3 enhancements
    lifeDaysRemaining.textContent = life.daysRemaining.toString();
    const completed = Math.max(0, Math.min(100, life.completionPercent));
    lifeCompletionPercent.textContent = `${completed}%`;
    lifeRemainingPercent.textContent = `${Math.max(0, 100 - completed)}%`;
    if (lifeCompletionRatioBar) {
      lifeCompletionRatioBar.style.width = `${completed}%`;
    }
    lifeExpectancyDate.textContent = life.expectancyDate.toLocaleDateString(
      "en-US",
      { year: "numeric", month: "short", day: "numeric" },
    );

    // Update Birthday countdown
    countdownDays.textContent = nextBDay.daysRemaining.toString();

    let countdownDesc = "";
    if (nextBDay.months > 0) {
      countdownDesc += `${nextBDay.months} month${nextBDay.months > 1 ? "s" : ""}`;
    }
    if (nextBDay.days > 0) {
      countdownDesc += `${nextBDay.months > 0 ? " & " : ""}${nextBDay.days} day${nextBDay.days > 1 ? "s" : ""}`;
    }
    if (countdownDesc === "") {
      countdownDesc = "Birthday is today!";
    } else {
      countdownDesc += " left";
    }
    countdownText.textContent = countdownDesc;

    // Countdown Clock text (format: DD:HH:MM:SS)
    const pad = (num: number) => num.toString().padStart(2, "0");
    countdownClock.textContent = `${pad(nextBDay.daysRemaining)}D : ${pad(nextBDay.hours)}H : ${pad(nextBDay.minutes)}M : ${pad(nextBDay.seconds)}S`;

    // SVG Progress Circular Offset (Circumference of radius 70 is 2 * PI * 70 = 439.8, round to 440)
    const circumference = 440;
    // Year progress is estimated based on remaining days of 365
    const progressPercent = Math.min(
      1,
      Math.max(0, 1 - nextBDay.daysRemaining / 365.25),
    );
    const strokeOffset = circumference * (1 - progressPercent);
    if (countdownProgress) {
      countdownProgress.style.strokeDashoffset = strokeOffset.toString();
    }

    // Update static profile only on firstLoad or when it changes
    if (firstLoad) {
      const daysOfWeek = [
        "Sunday",
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
      ];
      profileDayBorn.textContent = daysOfWeek[activeBirthDate.getDay()];

      profileZodiacSymbol.textContent = `${zodiac.symbol} ${zodiac.name}`;
      profileZodiacName.classList.add("hidden");

      profileChineseSymbol.textContent = chineseZ.symbol;
      profileChineseName.textContent = chineseZ.name;
      profileChineseElement.textContent = chineseZ.element;
      profileChineseTraits.textContent = `Year of the ${chineseZ.name} (${chineseZ.element}): ${chineseZ.traits}`;

      // Render Milestones Roadmap
      renderMilestonesRoadmap(activeBirthDate, now);
    }

    // Phase 3: Age Comparison Engine
    const comparisonCards = calculateAgeComparisonCards(activeBirthDate, now);
    renderComparisonCards(comparisonCards, comparisonCardsContainer);

    // Phase 3: Historical Context
    const historicalContext = calculateHistoricalContext(activeBirthDate, now);
    renderHistoricalContext(historicalContext, historicalContextContainer);

    // Born In Snapshot
    if (firstLoad) {
      const bornIn = calculateBornInSnapshot(activeBirthDate);
      renderBornInSnapshot(bornIn, bornInContainer);
    }

    // Keep age preview in Share Card updated
    shareCardAge.textContent = `${age.years} Years`;
    shareCardDays.textContent = `${totalUnits.days.toLocaleString()} Days Lived`;
    shareCardCountdown.textContent =
      nextBDay.daysRemaining > 0 ? `${nextBDay.daysRemaining} Days` : "Today!";
    shareCardProgressEl.textContent = `${life.completionPercent}%`;
    shareCardGenerationEl.textContent = getGenerationLabel(
      activeBirthDate.getFullYear(),
    );
    shareCardZodiacEl.textContent = `${zodiac.name} ${zodiac.symbol}`;
  }

  function renderComparisonCards(cards: any[], container: HTMLElement) {
    container.innerHTML = "";
    cards.forEach((c) => {
      const node = document.createElement("div");
      node.className =
        "bg-canvas-soft border border-hairline rounded-lg p-4 shadow-level-1";
      node.innerHTML = `
        <div class="flex items-start justify-between gap-3">
          <div>
            <div class="font-mono text-[10px] text-mute uppercase tracking-widest">Age Comparison</div>
            <h5 class="text-sm font-semibold text-ink mt-1">${c.title}</h5>
          </div>
          <div class="text-xs font-mono text-link font-semibold">${c.kind === "olderBy" ? "▲" : c.kind === "youngerBy" ? "▼" : "★"}</div>
        </div>
        <div class="mt-3 text-lg font-bold tracking-tight text-ink tabular-nums">${c.valueText}</div>
        ${c.subtitle ? `<p class="text-xs text-body leading-relaxed mt-1 select-text">${c.subtitle}</p>` : ""}
      `;
      container.appendChild(node);
    });
  }

  function renderHistoricalContext(cards: any[], container: HTMLElement) {
    container.innerHTML = "";
    cards.forEach((c) => {
      const formattedDate = new Date(c.date).toLocaleDateString("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
      });
      const node = document.createElement("div");
      node.className =
        "bg-canvas-soft border border-hairline rounded-lg p-4 shadow-level-1";
      node.innerHTML = `
        <div class="flex items-center justify-between gap-3">
          <div class="font-mono text-[10px] text-mute uppercase tracking-widest">Historical Milestone</div>
          <div class="font-mono text-[10px] text-link font-semibold">${formattedDate}</div>
        </div>
        <h5 class="text-sm font-semibold text-ink mt-2">${c.title}</h5>
        <p class="text-xs text-body leading-relaxed mt-1 select-text">${c.description}</p>
      `;
      container.appendChild(node);
    });

    if (cards.length === 0) {
      const empty = document.createElement("div");
      empty.className =
        "col-span-full bg-canvas-soft border border-hairline rounded-lg p-4 text-xs text-body";
      empty.textContent = "Coming in a future update.";
      container.appendChild(empty);
    }
  }

  function renderBornInSnapshot(snapshot: any, container: HTMLElement) {
    container.innerHTML = "";
    const node = document.createElement("div");
    node.className =
      "bg-canvas border border-hairline rounded-lg p-6 shadow-level-2";
    node.innerHTML = `
      <div class="flex items-center gap-2 mb-4">
        <div class="w-8 h-8 rounded-sm bg-canvas-soft border border-hairline flex items-center justify-center text-primary">
          <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 class="text-sm font-semibold text-ink uppercase tracking-wider font-mono">Born In</h3>
        <span class="font-mono text-[10px] text-mute uppercase tracking-widest ml-auto">${snapshot.birthYear}</span>
      </div>
      <div class="flex items-baseline gap-3 mb-4">
        <span class="text-3xl font-bold tracking-tight text-ink">${snapshot.birthYear}</span>
        <span class="font-mono text-xs text-link font-semibold uppercase tracking-wider">${snapshot.generation}</span>
      </div>
      ${
        snapshot.notableEvents.length > 0
          ? `
        <div class="space-y-2 pt-3 border-t border-hairline">
          <span class="font-mono text-[10px] text-mute uppercase tracking-widest font-semibold">Notable Events</span>
          ${snapshot.notableEvents
            .map(
              (e: string) => `
            <div class="flex items-start gap-2 text-xs text-body">
              <span class="text-link mt-0.5 shrink-0">—</span>
              <span>${e}</span>
            </div>
          `,
            )
            .join("")}
        </div>
      `
          : ""
      }
    `;
    container.appendChild(node);
  }

  // 7. Render Timeline milestones
  function renderMilestonesRoadmap(birthDate: Date, now: Date) {
    const milestones = calculateMilestones(birthDate, now);
    milestonesTimeline.innerHTML = "";

    milestones.forEach((milestone: any, idx: number) => {
      const isPast = milestone.isPast;
      const formattedDate = milestone.date.toLocaleDateString("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
      });

      const itemNode = document.createElement("div");
      itemNode.className = "relative animate-fade-in milestone-card";
      itemNode.style.animationDelay = `${idx * 0.05}s`;

      // Find the milestone indicator node layout
      let indicatorHtml = "";
      let highlightClass = "";

      if (isPast) {
        // Achieved milestone - small green checkmark or neutral ink icon
        indicatorHtml = `
          <div class="absolute -left-[31px] md:-left-[39px] top-1 w-5 h-5 md:w-7 md:h-7 rounded-full bg-canvas border border-hairline flex items-center justify-center text-link shadow-level-1">
            <svg class="w-3 h-3 md:w-4 md:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
        `;
        highlightClass = "opacity-60";
      } else {
        // Future milestone
        // If it's the very first future milestone, highlight it as the "next landmark"!
        const previousWasPast = idx > 0 ? milestones[idx - 1].isPast : false;
        const isNextUpcoming = idx === 0 ? true : previousWasPast;

        if (isNextUpcoming) {
          indicatorHtml = `
            <div class="absolute -left-[35px] md:-left-[43px] top-0.5 w-7 h-7 md:w-9 md:h-9 rounded-full bg-canvas border-2 border-link flex items-center justify-center text-link shadow-level-2 z-10 animate-pulse">
              <svg class="w-3.5 h-3.5 md:w-5 md:h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
          `;
          highlightClass =
            "border border-link/20 ring-2 ring-link/5 rounded-md p-4 bg-canvas shadow-level-3";
        } else {
          indicatorHtml = `
            <div class="absolute -left-[29px] md:-left-[37px] top-1.5 w-4 h-4 md:w-6 md:h-6 rounded-full bg-canvas border border-hairline flex items-center justify-center text-mute shadow-level-1">
              <span class="w-1.5 h-1.5 rounded-full bg-hairline-strong"></span>
            </div>
          `;
          highlightClass =
            "border border-hairline rounded-sm p-4 bg-canvas-soft shadow-level-1";
        }
      }

      // Generate HTML
      let footerHtml = "";
      if (isPast) {
        footerHtml = `<span class="font-mono text-[9px] text-mute uppercase tracking-widest font-semibold">Achieved</span>`;
      } else {
        footerHtml = `<span class="font-mono text-[9px] text-link uppercase tracking-widest font-semibold">In ${milestone.daysDifference.toLocaleString()} Days</span>`;
      }

      itemNode.innerHTML = `
        ${indicatorHtml}
        <div class="ml-4 md:ml-6 flex flex-col md:flex-row md:items-center justify-between gap-2 ${highlightClass}">
          <div>
            <h4 class="text-sm font-semibold text-ink leading-tight">${milestone.label}</h4>
            <p class="text-[11px] text-body mt-0.5">${formattedDate}</p>
          </div>
          <div class="flex items-center shrink-0">
            ${footerHtml}
          </div>
        </div>
      `;

      milestonesTimeline.appendChild(itemNode);
    });

    // End-cap node after the last milestone
    const endNode = document.createElement("div");
    endNode.className = "relative animate-fade-in";
    endNode.innerHTML = `
      <div class="absolute -left-[29px] md:-left-[37px] top-1.5 w-4 h-4 md:w-6 md:h-6 rounded-full bg-canvas border border-dashed border-hairline-strong flex items-center justify-center text-mute">
        <span class="font-mono text-[9px] font-bold">∞</span>
      </div>
      <div class="ml-4 md:ml-6 border border-dashed border-hairline rounded-sm p-4 bg-canvas-soft">
        <h4 class="text-sm font-semibold text-body leading-tight">Life continues…</h4>
        <p class="text-[11px] text-mute mt-0.5">Beyond 100 years</p>
      </div>
    `;
    milestonesTimeline.appendChild(endNode);
  }

  // 8. Copy Summary text to clipboard
  copySummaryBtn.addEventListener("click", () => {
    if (!activeBirthDate) return;
    const now = new Date();
    const age = calculateExactAge(activeBirthDate, now);
    const nextBDay = calculateNextBirthday(activeBirthDate, now);
    const units = calculateTotalUnits(activeBirthDate, now);
    const zodiac = getZodiacSign(activeBirthDate);
    const chineseZ = getChineseZodiac(activeBirthDate.getFullYear());

    let bdayText = "";
    if (nextBDay.months > 0 && nextBDay.days > 0) {
      bdayText = `${nextBDay.months} months and ${nextBDay.days} days`;
    } else if (nextBDay.months > 0) {
      bdayText = `${nextBDay.months} months`;
    } else if (nextBDay.days > 0) {
      bdayText = `${nextBDay.days} days`;
    } else {
      bdayText = "today!";
    }

    const message =
      `I am exactly ${age.years} years, ${age.months} months, and ${age.days} days old today!\n` +
      `Total days lived: ${units.days.toLocaleString()} days 🌏\n` +
      `Next birthday in: ${bdayText}\n` +
      `Zodiac: ${zodiac.name} ${zodiac.symbol}  |  Chinese Zodiac: ${chineseZ.name} ${chineseZ.symbol}\n` +
      `Calculate your exact age at: ${window.location.origin}`;

    navigator.clipboard
      .writeText(message)
      .then(() => {
        copyBtnText.textContent = "Copied to Clipboard!";
        setTimeout(() => {
          copyBtnText.textContent = "Copy Summary Text";
        }, 2000);
      })
      .catch((err) => {
        console.error("Clipboard copy failed", err);
      });
  });

  // 9. Web Share Life Summary (Premium)
  shareWebBtn.addEventListener("click", async () => {
    if (!activeBirthDate) return;

    const now = new Date();
    const age = calculateExactAge(activeBirthDate, now);
    const nextBDay = calculateNextBirthday(activeBirthDate, now);
    const units = calculateTotalUnits(activeBirthDate, now);
    const zodiac = getZodiacSign(activeBirthDate);
    const chineseZ = getChineseZodiac(activeBirthDate.getFullYear());

    let bdayText = "";
    if (nextBDay.months > 0 && nextBDay.days > 0) {
      bdayText = `${nextBDay.months} months and ${nextBDay.days} days`;
    } else if (nextBDay.months > 0) {
      bdayText = `${nextBDay.months} months`;
    } else if (nextBDay.days > 0) {
      bdayText = `${nextBDay.days} days`;
    } else {
      bdayText = "today!";
    }

    const shareText =
      `I am exactly ${age.years} years, ${age.months} months, and ${age.days} days old today!\n` +
      `Total days lived: ${units.days.toLocaleString()} days 🌏\n` +
      `Next birthday in: ${bdayText}\n` +
      `Zodiac: ${zodiac.name} ${zodiac.symbol}  |  Chinese Zodiac: ${chineseZ.name} ${chineseZ.symbol}\n` +
      `Calculate your exact age at: ${window.location.origin}`;

    try {
      // Prefer native Web Share API
      if (navigator.share) {
        await navigator.share({
          title: "Age Calculator — Life Summary",
          text: shareText,
          url: window.location.origin,
        });
        copyBtnText.textContent = "Shared!";
        setTimeout(() => {
          copyBtnText.textContent = "Copy Summary Text";
        }, 2000);
        return;
      }

      // Fallback: clipboard copy
      await navigator.clipboard.writeText(shareText);
      copyBtnText.textContent = "Copied for sharing!";
      setTimeout(() => {
        copyBtnText.textContent = "Copy Summary Text";
      }, 2000);
    } catch (err) {
      console.error("Web share failed", err);
    }
  });

  // 9. Download Share Card (HTML5 Canvas PNG Renderer - Premium)
  downloadCardBtn.addEventListener("click", () => {
    if (!activeBirthDate) return;
    const now = new Date();
    const age = calculateExactAge(activeBirthDate, now);
    const nextBDay = calculateNextBirthday(activeBirthDate, now);
    const units = calculateTotalUnits(activeBirthDate, now);
    const zodiac = getZodiacSign(activeBirthDate);
    const life = calculateLifeProgress(
      activeBirthDate,
      now,
      parseInt(lifeExpectancyYearsInput.value || "85", 10) || 85,
    );
    const generation = getGenerationLabel(activeBirthDate.getFullYear());

    const canvas = document.getElementById(
      "share-card-canvas",
    ) as HTMLCanvasElement;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    // Premium glass-effect background
    const isDark =
      document.documentElement.getAttribute("data-theme") === "dark";
    const bgColor = isDark ? "#0b0b0f" : "#ffffff";
    const textColor = isDark ? "#ffffff" : "#171717";
    const bodyColor = isDark ? "rgba(255,255,255,0.78)" : "#4d4d4d";
    const muteColor = isDark ? "rgba(255,255,255,0.52)" : "#888888";
    const linkColor = isDark ? "#79a9ff" : "#0070f3";
    const hairlineColor = isDark ? "rgba(255,255,255,0.16)" : "#ebebeb";

    ctx.fillStyle = bgColor;
    ctx.fillRect(0, 0, 1200, 630);

    // Gradient mesh spots
    const spots = [
      { x: 600, y: 0, r: 600, c: "rgba(0, 112, 243, 0.08)" },
      { x: 0, y: 0, r: 500, c: "rgba(80, 227, 194, 0.1)" },
      { x: 1200, y: 0, r: 500, c: "rgba(255, 0, 128, 0.06)" },
      { x: 600, y: 630, r: 400, c: "rgba(245, 166, 35, 0.04)" },
    ];
    for (const s of spots) {
      const g = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, s.r);
      g.addColorStop(0, s.c);
      g.addColorStop(1, "rgba(255, 255, 255, 0)");
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, 1200, 630);
    }

    // Card frame
    ctx.strokeStyle = hairlineColor;
    ctx.lineWidth = 1;
    const m = 40;
    const w = 1120;
    const h = 550;
    ctx.beginPath();
    ctx.roundRect(m, m, w, h, 16);
    ctx.stroke();

    // Optional glass overlay
    ctx.fillStyle = isDark
      ? "rgba(11, 11, 15, 0.4)"
      : "rgba(255, 255, 255, 0.3)";
    ctx.beginPath();
    ctx.roundRect(m, m, w, h, 16);
    ctx.fill();

    // Header
    ctx.fillStyle = muteColor;
    ctx.font = "bold 18px monospace";
    ctx.textAlign = "left";
    ctx.fillText("AGE REPORT", 100, 100);

    ctx.fillStyle = textColor;
    ctx.font = "bold 20px sans-serif";
    ctx.textAlign = "right";
    ctx.fillText("AGE CALCULATOR.", 1100, 100);

    // Generation badge
    ctx.fillStyle = linkColor;
    ctx.font = "bold 14px monospace";
    ctx.textAlign = "left";
    ctx.fillText(generation, 100, 130);

    // Hero Age Display
    ctx.fillStyle = textColor;
    ctx.font = "bold 110px sans-serif";
    ctx.textAlign = "center";
    ctx.fillText(`${age.years}`, 600, 300);
    ctx.font = "bold 28px sans-serif";
    ctx.fillText("YEARS OLD", 600, 340);

    // Days lived
    ctx.fillStyle = linkColor;
    ctx.font = "bold 22px monospace";
    ctx.textAlign = "left";
    ctx.fillText(`${units.days.toLocaleString()} Days Lived`, 100, 410);

    // Bottom stats row
    const bdayStr =
      nextBDay.daysRemaining > 0 ? `${nextBDay.daysRemaining}d` : "Today!";
    const lifeStr = `${life.completionPercent}%`;
    const zodiacStr = `${zodiac.name} ${zodiac.symbol}`;

    ctx.fillStyle = muteColor;
    ctx.font = "12px monospace";
    ctx.textAlign = "left";
    ctx.fillText("NEXT BIRTHDAY", 100, 470);
    ctx.fillText("LIFE PROGRESS", 460, 470);
    ctx.fillText("ZODIAC", 820, 470);

    ctx.fillStyle = textColor;
    ctx.font = "bold 28px sans-serif";
    ctx.fillText(bdayStr, 100, 510);
    ctx.fillText(lifeStr, 460, 510);
    ctx.fillText(zodiacStr, 820, 510);

    // Privacy footer
    ctx.fillStyle = muteColor;
    ctx.font = "14px monospace";
    ctx.textAlign = "right";
    ctx.fillText("100% private · local browser", 1100, 560);

    // Trigger download
    const link = document.createElement("a");
    const birthISO = activeBirthDate.toISOString().slice(0, 10);
    link.download = `age-calculator-${birthISO}-${age.years}y.png`;
    link.href = canvas.toDataURL("image/png");
    link.click();
  });

  // Premium badge click-to-toggle (mobile-friendly tooltip)
  document.addEventListener("click", (e) => {
    const badge = (e.target as HTMLElement).closest(".premium-badge");
    if (!badge) {
      document.querySelectorAll(".premium-tooltip").forEach((t) => {
        t.classList.add("opacity-0", "invisible");
        t.classList.remove("opacity-100", "visible");
      });
      return;
    }
    const tooltip = badge.querySelector(".premium-tooltip") as HTMLElement;
    if (!tooltip) return;
    const isOpen = tooltip.classList.contains("visible");
    document.querySelectorAll(".premium-tooltip").forEach((t) => {
      t.classList.add("opacity-0", "invisible");
      t.classList.remove("opacity-100", "visible");
    });
    if (!isOpen) {
      tooltip.classList.remove("opacity-0", "invisible");
      tooltip.classList.add("opacity-100", "visible");
    }
    e.stopPropagation();
  });

  // View transition smooth scroll for internal links
  document.addEventListener("click", (e) => {
    const link = (e.target as HTMLElement).closest("a[href^='/']");
    if (!link || link.getAttribute("href") === "#") return;
    document.startViewTransition?.(() => {});
  });
</script>
