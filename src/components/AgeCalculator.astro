  const shareCardZodiac = document.getElementById("share-card-zodiac")!;

  // 1. Initial State / LocalStorage loading
  window.addEventListener("DOMContentLoaded", () => {
    // Theme (Dark Mode) persistence
    const savedTheme = localStorage.getItem("theme");
    const theme =
      savedTheme === "dark" || savedTheme === "light" ? savedTheme : "light";
    document.documentElement.setAttribute("data-theme", theme);

    const themeToggle = document.getElementById("theme-toggle");
    if (themeToggle) {
      themeToggle.textContent = theme === "dark" ? "Light Mode" : "Dark Mode";
      themeToggle.addEventListener("click", () => {
        const current = document.documentElement.getAttribute("data-theme");
        const next = current === "dark" ? "light" : "dark";
        document.documentElement.setAttribute("data-theme", next);
        localStorage.setItem("theme", next);
        themeToggle.textContent = next === "dark" ? "Light Mode" : "Dark Mode";

        // Re-render share card canvas backgrounds for theme coherence
        if (activeBirthDate) {
          runCalculations(false);
        }
      });
    }

    const savedDate = localStorage.getItem("birth-date");
    const savedTime = localStorage.getItem("birth-time");

    // Set default max date to today
    const today = new Date().toISOString().split("T")[0];
    birthDateInput.max = today;

    // Life expectancy preference (V2)
    const savedExpectancy = localStorage.getItem("life-expectancy-years");
    const defaultExpectancy = 85;
    const parsedExpectancy = savedExpectancy
      ? Math.min(130, Math.max(1, parseInt(savedExpectancy, 10)))
      : defaultExpectancy;
    lifeExpectancyYearsInput.value = parsedExpectancy.toString();
    localStorage.setItem("life-expectancy-years", parsedExpectancy.toString());

    // Persist preference on change
    lifeExpectancyYearsInput.addEventListener("input", () => {
      const v = Math.min(
        130,
        Math.max(
          1,
          parseInt(lifeExpectancyYearsInput.value || "0", 10) ||
            defaultExpectancy,
        ),
      );
      lifeExpectancyYearsInput.value = v.toString();
      localStorage.setItem("life-expectancy-years", v.toString());

      // Update dashboard if active
      if (activeBirthDate) runCalculations(false);
    });

    if (savedDate) {
      birthDateInput.value = savedDate;
      if (savedTime) birthTimeInput.value = savedTime;

      const birthDate = parseBirthDateTime(savedDate, savedTime || "00:00");
      if (birthDate && birthDate.getTime() < new Date().getTime()) {
        activateDashboard(birthDate);
      }
    }
  });

  // Helper to parse birthdate inputs
  function parseBirthDateTime(dateStr: string, timeStr: string): Date | null {
    if (!dateStr) return null;
    const time = timeStr || "00:00";
    const date = new Date(`${dateStr}T${time}`);
    return isNaN(date.getTime()) ? null : date;
  }

  // 2. Tab Navigation Trigger
  const tabButtons = document.querySelectorAll(".tab-btn");
  const tabPanels = document.querySelectorAll(".tab-panel");

  tabButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const targetTab = btn.getAttribute("data-tab");

      // Update buttons style
      tabButtons.forEach((b) => {
        b.classList.remove("active", "text-on-primary", "bg-primary");
        b.classList.add("text-body", "hover:text-ink", "hover:bg-canvas");
      });
      btn.classList.add("active", "text-on-primary", "bg-primary");
      btn.classList.remove("text-body", "hover:text-ink", "hover:bg-canvas");

      // Update panel visibility
      tabPanels.forEach((panel) => {
        panel.classList.add("hidden");
      });
      document.getElementById(`tab-${targetTab}`)?.classList.remove("hidden");
    });
  });

  // 3. Form Submission
  ageForm.addEventListener("submit", (e) => {
    e.preventDefault();
    dateError.classList.add("hidden");

    const dateVal = birthDateInput.value;
    const timeVal = birthTimeInput.value || "00:00";

    const birthDate = parseBirthDateTime(dateVal, timeVal);

    if (!birthDate || birthDate.getTime() >= new Date().getTime()) {
      dateError.classList.remove("hidden");
      return;
    }

    // Save to LocalStorage
    localStorage.setItem("birth-date", dateVal);
    localStorage.setItem("birth-time", timeVal);

    activateDashboard(birthDate);
  });

  // 4. Activate Dashboard
  function activateDashboard(birthDate: Date) {
    activeBirthDate = birthDate;

    // Hide form, show dashboard
    landingView.classList.add("hidden");
    dashboardView.classList.remove("hidden");
    resetBtn.classList.remove("hidden");

    // Run first calculations
    runCalculations(true);

    // Set interval for live counter updates (every second)
    if (timerId) clearInterval(timerId);
    timerId = setInterval(() => runCalculations(false), 1000);
  }

  // 5. Reset Form Actions
  resetBtn.addEventListener("click", () => {
    // Clear state
    activeBirthDate = null;
    if (timerId) {
      clearInterval(timerId);
      timerId = null;
    }

    // Clear inputs and LocalStorage
    birthDateInput.value = "";
    birthTimeInput.value = "";
    localStorage.removeItem("birth-date");
    localStorage.removeItem("birth-time");

    // Hide dashboard, show form
    dashboardView.classList.add("hidden");
    resetBtn.classList.add("hidden");
    landingView.classList.remove("hidden");

    // Reset tabs
    document.getElementById("tab-btn-overview")?.click();
  });

  // 6. Primary Calculation Runner
  // runs once with full = true (renders DOM nodes like Milestones that don't need second-by-second changes)
  function runCalculations(firstLoad: boolean) {
    if (!activeBirthDate) return;
    const now = new Date();

    // Calculate details
    const age = calculateExactAge(activeBirthDate, now);
    const nextBDay = calculateNextBirthday(activeBirthDate, now);
    const totalUnits = calculateTotalUnits(activeBirthDate, now);
    const zodiac = getZodiacSign(activeBirthDate);
    const chineseZ = getChineseZodiac(activeBirthDate.getFullYear());
    const stats = calculateStats(activeBirthDate, now);

    // Update Exact Age Display
    yCounter.textContent = age.years.toString();
    mCounter.textContent = age.months.toString();
    dCounter.textContent = age.days.toString();
    hCounter.textContent = age.hours.toString();
    minCounter.textContent = age.minutes.toString();
    sCounter.textContent = age.seconds.toString();

    // Update Total Units
    mTotal.textContent = totalUnits.months.toLocaleString();
    wTotal.textContent = totalUnits.weeks.toLocaleString();
    dTotal.textContent = totalUnits.days.toLocaleString();
    hTotal.textContent = totalUnits.hours.toLocaleString();
    minTotal.textContent = totalUnits.minutes.toLocaleString();
    sTotal.textContent = totalUnits.seconds.toLocaleString();

    // Update Cosmic / Biological stats
    statHeartbeats.textContent = stats.heartbeats.toLocaleString();
    statBreaths.textContent = stats.breaths.toLocaleString();
    statMoonOrbits.textContent = stats.moonOrbits.toLocaleString();
    statSolarTravel.textContent = stats.solarTravelKm.toLocaleString();

    // Life Statistics Intelligence (V2)
    const lifeStats = calculateLifeStatistics(activeBirthDate, now);
    statWeekendsLived.textContent = lifeStats.weekendsLived.toLocaleString();
    statLeapYearsWitnessed.textContent =
      lifeStats.leapYearsWitnessed.toLocaleString();
    statOlympicsSeen.textContent = lifeStats.olympicsSeen.toLocaleString();
    statWorldCupsSeen.textContent = lifeStats.worldCupsSeen.toLocaleString();
    statMoonCyclesCompleted.textContent =
      lifeStats.moonCyclesCompleted.toLocaleString();
    statEarthOrbitsCompleted.textContent =
      lifeStats.earthOrbitsCompleted.toLocaleString();

    // Update Planetary Ages (V2)
    const planetary = calculatePlanetaryAges(activeBirthDate, now);
    planetaryMercury.textContent = planetary.mercury.toFixed(1);
    planetaryVenus.textContent = planetary.venus.toFixed(1);
    planetaryMars.textContent = planetary.mars.toFixed(1);
    planetaryJupiter.textContent = planetary.jupiter.toFixed(1);
    planetarySaturn.textContent = planetary.saturn.toFixed(1);

    // Life Progress Dashboard (V2)
    const expectancyYears = Math.min(
      130,
      Math.max(1, parseInt(lifeExpectancyYearsInput.value || "85", 10) || 85),
    );
    const life = calculateLifeProgress(activeBirthDate, now, expectancyYears);
    lifeYearsRemaining.textContent = life.yearsRemaining.toString();
    lifeMonthsRemaining.textContent = life.monthsRemaining.toString();
    lifeWeeksRemaining.textContent = life.weeksRemaining.toString();
    lifeCompletionPercent.textContent = `${life.completionPercent}%`;
    lifeExpectancyDate.textContent = life.expectancyDate.toLocaleDateString(
      "en-US",
      { year: "numeric", month: "short", day: "numeric" },
    );

    // Update Birthday countdown
    countdownDays.textContent = nextBDay.daysRemaining.toString();

    let countdownDesc = "";
    if (nextBDay.months > 0) {
      countdownDesc += `${nextBDay.months} month${nextBDay.months > 1 ? "s" : ""}`;
    }
    if (nextBDay.days > 0) {
      countdownDesc += `${nextBDay.months > 0 ? " & " : ""}${nextBDay.days} day${nextBDay.days > 1 ? "s" : ""}`;
    }
    if (countdownDesc === "") {
      countdownDesc = "Birthday is today!";
    } else {
      countdownDesc += " left";
    }
    countdownText.textContent = countdownDesc;

    // Countdown Clock text (format: DD:HH:MM:SS)
    const pad = (num: number) => num.toString().padStart(2, "0");
    countdownClock.textContent = `${pad(nextBDay.daysRemaining)}D : ${pad(nextBDay.hours)}H : ${pad(nextBDay.minutes)}M : ${pad(nextBDay.seconds)}S`;

    // SVG Progress Circular Offset (Circumference of radius 70 is 2 * PI * 70 = 439.8, round to 440)
    const circumference = 440;
    // Year progress is estimated based on remaining days of 365
    const progressPercent = Math.min(
      1,
      Math.max(0, 1 - nextBDay.daysRemaining / 365.25),
    );
    const strokeOffset = circumference * (1 - progressPercent);
    if (countdownProgress) {
      countdownProgress.style.strokeDashoffset = strokeOffset.toString();
    }

    // Update static profile only on firstLoad or when it changes
    if (firstLoad) {
      const daysOfWeek = [
        "Sunday",
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
      ];
      profileDayBorn.textContent = daysOfWeek[activeBirthDate.getDay()];

      profileZodiacSymbol.textContent = zodiac.symbol;
      profileZodiacName.textContent = zodiac.name;
      profileZodiacDates.textContent = zodiac.dates;

      profileChineseSymbol.textContent = chineseZ.symbol;
      profileChineseName.textContent = chineseZ.name;
      profileChineseElement.textContent = chineseZ.element;
      profileChineseTraits.textContent = `Year of the ${chineseZ.name} (${chineseZ.element}): ${chineseZ.traits}`;

      // Render static share card text preview
      const dateOptions: Intl.DateTimeFormatOptions = {
        year: "numeric",
        month: "long",
        day: "numeric",
      };
      shareCardDate.textContent = activeBirthDate.toLocaleDateString(
        "en-US",
        dateOptions,
      );
      shareCardZodiac.textContent = `${zodiac.name} ${zodiac.symbol}  |  ${chineseZ.element} ${chineseZ.name} ${chineseZ.symbol}`;

      // Render Milestones Roadmap
      renderMilestonesRoadmap(activeBirthDate, now);
    }

    // Keep age preview in Share Card updated
    shareCardAge.textContent = `${age.years}Y, ${age.months}M, ${age.days}D`;
    shareCardDays.textContent = `${totalUnits.days.toLocaleString()} Days Lived`;
  }

  // 7. Render Timeline milestones
  function renderMilestonesRoadmap(birthDate: Date, now: Date) {
    const milestones = calculateMilestones(birthDate, now);
    milestonesTimeline.innerHTML = "";

    milestones.forEach((milestone: any, idx: number) => {
      const isPast = milestone.isPast;
      const formattedDate = milestone.date.toLocaleDateString("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
      });

      const itemNode = document.createElement("div");
      itemNode.className = "relative animate-fade-in";
      itemNode.style.animationDelay = `${idx * 0.05}s`;

      // Find the milestone indicator node layout
      let indicatorHtml = "";
      let highlightClass = "";

      if (isPast) {
        // Achieved milestone - small green checkmark or neutral ink icon
        indicatorHtml = `
          <div class="absolute -left-[31px] md:-left-[39px] top-1 w-5 h-5 md:w-7 md:h-7 rounded-full bg-canvas border border-hairline flex items-center justify-center text-link shadow-level-1">
            <svg class="w-3 h-3 md:w-4 md:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
        `;
        highlightClass = "opacity-60";
      } else {
        // Future milestone
        // If it's the very first future milestone, highlight it as the "next landmark"!
        const previousWasPast = idx > 0 ? milestones[idx - 1].isPast : false;
        const isNextUpcoming = idx === 0 ? true : previousWasPast;

        if (isNextUpcoming) {
          indicatorHtml = `
            <div class="absolute -left-[35px] md:-left-[43px] top-0.5 w-7 h-7 md:w-9 md:h-9 rounded-full bg-canvas border-2 border-link flex items-center justify-center text-link shadow-level-2 z-10 animate-pulse">
              <svg class="w-3.5 h-3.5 md:w-5 md:h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
          `;
          highlightClass =
            "border border-link/20 ring-2 ring-link/5 rounded-md p-4 bg-canvas shadow-level-3";
        } else {
          indicatorHtml = `
            <div class="absolute -left-[29px] md:-left-[37px] top-1.5 w-4 h-4 md:w-6 md:h-6 rounded-full bg-canvas border border-hairline flex items-center justify-center text-mute shadow-level-1">
              <span class="w-1.5 h-1.5 rounded-full bg-hairline-strong"></span>
            </div>
          `;
          highlightClass =
            "border border-hairline rounded-sm p-4 bg-canvas-soft shadow-level-1";
        }
      }

      // Generate HTML
      let footerHtml = "";
      if (isPast) {
        footerHtml = `<span class="font-mono text-[9px] text-mute uppercase tracking-widest font-semibold">Achieved</span>`;
      } else {
        footerHtml = `<span class="font-mono text-[9px] text-link uppercase tracking-widest font-semibold">In ${milestone.daysDifference.toLocaleString()} Days</span>`;
      }

      itemNode.innerHTML = `
        ${indicatorHtml}
        <div class="ml-4 md:ml-6 flex flex-col md:flex-row md:items-center justify-between gap-2 ${highlightClass}">
          <div>
            <h4 class="text-sm font-semibold text-ink leading-tight">${milestone.label}</h4>
            <p class="text-[11px] text-body mt-0.5">${formattedDate}</p>
          </div>
          <div class="flex items-center shrink-0">
            ${footerHtml}
          </div>
        </div>
      `;

      milestonesTimeline.appendChild(itemNode);
    });
  }

  // 8. Copy Summary text to clipboard
  copySummaryBtn.addEventListener("click", () => {
    if (!activeBirthDate) return;
    const now = new Date();
    const age = calculateExactAge(activeBirthDate, now);
    const nextBDay = calculateNextBirthday(activeBirthDate, now);
    const units = calculateTotalUnits(activeBirthDate, now);
    const zodiac = getZodiacSign(activeBirthDate);
    const chineseZ = getChineseZodiac(activeBirthDate.getFullYear());

    let bdayText = "";
    if (nextBDay.months > 0 && nextBDay.days > 0) {
      bdayText = `${nextBDay.months} months and ${nextBDay.days} days`;
    } else if (nextBDay.months > 0) {
      bdayText = `${nextBDay.months} months`;
    } else if (nextBDay.days > 0) {
      bdayText = `${nextBDay.days} days`;
    } else {
      bdayText = "today!";
    }

    const message =
      `I am exactly ${age.years} years, ${age.months} months, and ${age.days} days old today!\n` +
      `Total days lived: ${units.days.toLocaleString()} days 🌏\n` +
      `Next birthday in: ${bdayText}\n` +
      `Zodiac: ${zodiac.name} ${zodiac.symbol}  |  Chinese Zodiac: ${chineseZ.name} ${chineseZ.symbol}\n` +
      `Calculate your exact age at: ${window.location.origin}`;

    navigator.clipboard
      .writeText(message)
      .then(() => {
        copyBtnText.textContent = "Copied to Clipboard!";
        setTimeout(() => {
          copyBtnText.textContent = "Copy Summary Text";
        }, 2000);
      })
      .catch((err) => {
        console.error("Clipboard copy failed", err);
      });
  });

