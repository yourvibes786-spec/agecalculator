      `Total days lived: ${units.days.toLocaleString()} days 🌏\n` +
      `Next birthday in: ${bdayText}\n` +
      `Zodiac: ${zodiac.name} ${zodiac.symbol}  |  Chinese Zodiac: ${chineseZ.name} ${chineseZ.symbol}\n` +
      `Calculate your exact age at: ${window.location.origin}`;

    try {
      // Prefer native Web Share API
      if (navigator.share) {
        await navigator.share({
          title: "Age Calculator — Life Summary",
          text: shareText,
          url: window.location.origin,
        });
        copyBtnText.textContent = "Shared!";
        setTimeout(() => {
          copyBtnText.textContent = "Copy Summary Text";
        }, 2000);
