  // 9. Download Share Card (HTML5 Canvas PNG Renderer)
  downloadCardBtn.addEventListener("click", () => {
    if (!activeBirthDate) return;
    const now = new Date();
    const age = calculateExactAge(activeBirthDate, now);
    const units = calculateTotalUnits(activeBirthDate, now);
    const zodiac = getZodiacSign(activeBirthDate);
    const chineseZ = getChineseZodiac(activeBirthDate.getFullYear());

    const canvas = document.getElementById(
      "share-card-canvas",
    ) as HTMLCanvasElement;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    // Draw background (Vercel stark canvas style with soft gradient meshes)
    ctx.fillStyle = "#ffffff";
    ctx.fillRect(0, 0, 1200, 630);

    // Draw gradient accent circles
    // Blue spot top center
    let grad1 = ctx.createRadialGradient(600, 0, 0, 600, 0, 500);
    grad1.addColorStop(0, "rgba(0, 112, 243, 0.1)");
    grad1.addColorStop(1, "rgba(255, 255, 255, 0)");
    ctx.fillStyle = grad1;
    ctx.fillRect(0, 0, 1200, 630);

    // Mint/Cyan spot top left
    let grad2 = ctx.createRadialGradient(0, 0, 0, 0, 0, 500);
    grad2.addColorStop(0, "rgba(80, 227, 194, 0.12)");
    grad2.addColorStop(1, "rgba(255, 255, 255, 0)");
    ctx.fillStyle = grad2;
    ctx.fillRect(0, 0, 1200, 630);

    // Pink spot top right
    let grad3 = ctx.createRadialGradient(1200, 0, 0, 1200, 0, 500);
    grad3.addColorStop(0, "rgba(255, 0, 128, 0.08)");
    grad3.addColorStop(1, "rgba(255, 255, 255, 0)");
    ctx.fillStyle = grad3;
    ctx.fillRect(0, 0, 1200, 630);

    // Draw card inner border
    ctx.lineWidth = 1;
    ctx.strokeStyle = "#ebebeb";
    ctx.strokeRect(50, 50, 1100, 530);

    // Draw headers
    ctx.fillStyle = "#888888";
    ctx.font = "bold 20px monospace";
    ctx.fillText("AGE REPORT", 100, 110);

    // Draw date born
    const dateOptions: Intl.DateTimeFormatOptions = {
      year: "numeric",
      month: "long",
      day: "numeric",
    };
    const dateStr = activeBirthDate.toLocaleDateString("en-US", dateOptions);
    ctx.fillStyle = "#4d4d4d";
    ctx.font = "24px sans-serif";
    ctx.fillText(`Born: ${dateStr}`, 100, 155);

    // Brand watermark
    ctx.fillStyle = "#171717";
    ctx.font = "bold 24px sans-serif";
    ctx.fillText("AGE CALCULATOR.", 900, 110);

    // Large main counter representation
    ctx.fillStyle = "#171717";
    ctx.font = "bold 84px sans-serif";
    ctx.fillText(`${age.years} Years old.`, 100, 310);

    ctx.fillStyle = "#4d4d4d";
    ctx.font = "normal 36px sans-serif";
    ctx.fillText(
      `${age.months} months, ${age.days} days, ${age.hours} hours`,
      100,
      380,
    );

    // Total metrics lived
    ctx.fillStyle = "#0070f3";
    ctx.font = "bold 28px monospace";
    ctx.fillText(
      `${units.days.toLocaleString()} Days Lived on Earth`,
      100,
      450,
    );

    // Divider line
    ctx.lineWidth = 1;
    ctx.strokeStyle = "rgba(235, 235, 235, 0.6)";
    ctx.beginPath();
    ctx.moveTo(100, 500);
    ctx.lineTo(1100, 500);
    ctx.stroke();

    // Footer profiles
    ctx.fillStyle = "#888888";
    ctx.font = "20px sans-serif";
    ctx.fillText(
      `Astrology: ${zodiac.name} ${zodiac.symbol}  |  Lunar Zodiac: ${chineseZ.element} ${chineseZ.name} ${chineseZ.symbol}`,
      100,
      545,
    );

    ctx.fillStyle = "#888888";
    ctx.font = "16px monospace";
    ctx.fillText("Calculations 100% private & secure.", 810, 545);

    // Trigger download of canvas image
    const link = document.createElement("a");
    const birthISO = activeBirthDate.toISOString().slice(0, 10);
    link.download = `age-calculator-${birthISO}-${age.years}y.png`;
    link.href = canvas.toDataURL("image/png");
    link.click();
  });
</script>
