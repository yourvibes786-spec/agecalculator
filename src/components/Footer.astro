---
const version = 'v1.0.0';
---
<footer class="w-full bg-canvas/40 border-t border-hairline py-8">
  <div class="max-w-[1200px] mx-auto px-4 md:px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-1.5 font-mono text-[10px] text-mute font-semibold uppercase tracking-wider">
      <span>Age Calculator</span>
      <span>•</span>
      <span>{version}</span>
      <span>•</span>
      <span>Privacy-First</span>
    </div>
    <div class="text-[11px] text-mute flex gap-4 font-medium">
      <a href="/" class="hover:text-ink focus-ring rounded-sm">Home</a>
      <a href="/about" class="hover:text-ink focus-ring rounded-sm">About Us</a>
      <a href="/contact" class="hover:text-ink focus-ring rounded-sm">Contact</a>
      <a href="/privacy" class="hover:text-ink focus-ring rounded-sm">Privacy policy</a>
      <a href="/terms" class="hover:text-ink focus-ring rounded-sm">Terms of service</a>
    </div>
  </div>
</footer>
