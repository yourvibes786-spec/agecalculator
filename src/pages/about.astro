---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro'; // Import the reusable Footer component
const today = new Date();
const formattedDate = today.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title="About Us — Age Calculator" description="Learn about the Age Calculator project, its mission, and its commitment to privacy.">
  <div class="min-h-screen flex flex-col">
    <!-- Simple Nav Header -->
    <header class="sticky top-0 z-50 w-full bg-canvas/80 backdrop-blur-md border-b border-hairline shadow-level-1 min-h-14 md:min-h-16 transition-all">
      <div class="max-w-[1200px] mx-auto px-3 md:px-6 py-2 md:py-0 flex items-center justify-between">
        <a href="/" class="flex items-center gap-1.5 focus-ring rounded-sm py-1 shrink-0">
          <span class="font-mono text-[10px] md:text-xs font-semibold tracking-widest text-mute">0.0.1</span>
          <span class="font-sans font-semibold text-sm md:text-lg tracking-tight select-none text-ink leading-tight">AGE CALCULATOR.</span>
        </a>
        <a href="/"
          class="px-3 py-1.5 bg-canvas hover:bg-canvas-soft-2 text-ink border border-hairline rounded-sm font-mono text-[10px] md:text-xs font-semibold uppercase tracking-wider focus-ring transition cursor-pointer"
        >← Back to Home</a>
      </div>
    </header>

    <!-- Content -->
    <main class="flex-1 w-full max-w-3xl mx-auto px-4 md:px-6 py-12 md:py-20">
      <article class="prose prose-sm md:prose-base max-w-none">
        <h1 class="text-2xl md:text-3xl font-bold text-ink tracking-tight mb-2">About Age Calculator</h1>
        <p class="text-xs md:text-sm text-mute font-mono uppercase tracking-widest mb-8">Last updated: {formattedDate}</p>

        <div class="space-y-6 text-body text-sm md:text-base leading-relaxed">
          
          <section>
            <h2 class="text-lg font-semibold text-ink mb-3">Our Mission</h2>
            <p>At Age Calculator, our mission is to provide a simple, accurate, and exceptionally private tool for understanding time. We believe that personal calculations should remain personal, which is why every feature is designed with a strict 'privacy-first' philosophy. We aim to empower users with clear, reliable information without compromising their data.</p>
          </section>

          <section class="bg-canvas border border-hairline rounded-lg p-5 md:p-6">
            <h2 class="text-lg font-semibold text-ink mb-3">The Privacy Promise</h2>
            <p>Your trust is paramount. We are committed to a transparent and secure experience:</p>
            <ul class="space-y-4 mt-4">
              <li class="flex items-start gap-3">
                <span class="text-link shrink-0 mt-0.5 text-sm">✓</span>
                <div>
                  <strong class="text-ink font-semibold block">100% Local Calculations</strong>
                  <span class="text-body text-sm">All age calculations and milestone tracking occur directly in your browser. No data leaves your device.</span>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-link shrink-0 mt-0.5 text-sm">✓</span>
                <div>
                  <strong class="text-ink font-semibold block">No Data Collection</strong>
                  <span class="text-body text-sm">We do not collect, store, transmit, or sell any of your personal information or birth dates. Ever.</span>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-link shrink-0 mt-0.5 text-sm">✓</span>
                <div>
                  <strong class="text-ink font-semibold block">No Accounts, No Tracking</strong>
                  <span class="text-body text-sm">Use the tool without sign-ups, logins, or any form of tracking. Your anonymity is guaranteed.</span>
                </div>
              </li>
            </ul>
          </section>

          <section>
            <h2 class="text-lg font-semibold text-ink mb-3">Technology & Design</h2>
            <p>Built with Astro for performance and efficiency, and styled with Tailwind CSS to ensure a clean, modern, and responsive user experience. The design prioritizes clarity, speed, and a premium feel.</p>
          </section>

          <section>
            <h2 class="text-lg font-semibold text-ink mb-3">Our Commitment</h2>
            <p>We are dedicated to providing a reliable and trustworthy tool. By focusing on local processing and user privacy, we offer a unique experience in the world of online calculators.</p>
          </section>

          <div class="pt-6 border-t border-hairline">
            <a href="/"
              class="inline-flex items-center gap-2 px-4 py-2.5 bg-primary hover:bg-neutral-800 text-on-primary rounded-sm font-sans font-medium text-sm focus-ring transition shadow-level-2"
            >← Back to Age Calculator</a>
          </div>
        </div>
      </article>
    </main>

    <Footer /> {/* Replaced old footer HTML with the reusable component */}
  </div>
</Layout>
